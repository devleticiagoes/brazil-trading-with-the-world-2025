{
  "name": "Custom Theme",
  "dataColors": [
    "#71c4ef",
    "#2c38e5",
    "#00668c",
    "#d4eaf7",
    "#b6ccd8"
  ],
  "foreground": "#f9fafb",
  "background": "#1e293b",
  "foregroundNeutralSecondary": "#d1d5db",
  "backgroundLight": "#0f172a",
  "foregroundNeutralTertiary": "#d1d5db",
  "backgroundNeutral": "#334155",
  "tableAccent": "#71c4ef",
  "maximum": "#00668c",
  "center": "#2c38e5",
  "minimum": "#71c4ef",
  "bad": "#71c4ef",
  "neutral": "#2c38e5",
  "good": "#00668c",
  "textClasses": {
    "callout": {
      "color": "#f9fafb",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#f9fafb",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#f9fafb",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#f9fafb",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#334155"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#334155"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#334155"
              }
            },
            "border": {
              "solid": {
                "color": "#334155"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#0f172a"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#1e293b"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}